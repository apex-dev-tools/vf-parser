{
  "name": "@apexdevtools/vf-parser",
  "version": "2.0.0-SNAPSHOT",
  "author": "Apex Dev Tools Team <apexdevtools@gmail.com> (https://github.com/apex-dev-tools)",
  "bugs": "https://github.com/apex-dev-tools/vf-parser/issues",
  "description": "Salesforce Visualforce parser",
  "homepage": "https://github.com/apex-dev-tools/vf-parser",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apex-dev-tools/vf-parser.git"
  },
  "license": "BSD-3-Clause",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "scripts": {
    "antlr": "mvn exec:exec",
    "build": "npm run clean && npm run antlr && tsc",
    "build:test": "npm run build && npm test",
    "check": "node -e 'import(\"./dist/src/index.js\").then(m => m.check())'",
    "clean": "rm -rf dist",
    "init": "npm ci && npm run antlr",
    "lint": "eslint --cache --cache-location .eslintcache ./src --fix",
    "prepare": "patch-package",
    "prepack": "cp ../*.md .",
    "test": "jest --config jestconfig.json"
  },
  "files": [
    "dist/src",
    "patches"
  ],
  "bundleDependencies": [
    "antlr4"
  ],
  "dependencies": {
    "antlr4": "4.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "patch-package": "^8.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./antlr/*": "./dist/src/antlr/*.js",
    "./ThrowingErrorListener": "./dist/src/ThrowingErrorListener.js"
  }
}
