{
  "name": "vf-parser-build",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://github.com/apex-dev-tools/vf-parser",
  "repository": "apex-dev-tools/vf-parser",
  "scripts": {
    "build": "npm run build:npm && npm run build:jvm",
    "build:jvm": "mvn package -f jvm",
    "build:npm": "npm run --prefix npm build:test",
    "prepare": "husky",
    "init": "npm ci && npm run init:npm && npm run init:jvm",
    "init:jvm": "mvn exec:exec -f jvm",
    "init:npm": "npm run --prefix npm init"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-java": "^2.8.1"
  }
}
